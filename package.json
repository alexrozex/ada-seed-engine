{
  "name": "ada-seed-engine",
  "version": "0.1.0",
  "description": "Compile natural language intent into governed, self-monitoring, self-evolving multi-agent topologies for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ada": "./bin/ada.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./constraints": {
      "import": "./dist/constraints/index.js",
      "types": "./dist/constraints/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/compiler/index.js",
      "types": "./dist/compiler/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "bin/",
    "SKILL.md",
    "GEOMETRY.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "agents",
    "compiler",
    "governance",
    "motherlabs",
    "ada",
    "multi-agent",
    "topology",
    "seed"
  ],
  "author": "Motherlabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexrozex/ada-seed-engine.git"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
